<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>ICONIC TV — Official India Broadcaster | CricketTV</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07070c;--bg2:#0f0f16;--bg3:#14141e;--bg4:#1a1a26;
  --accent:#e63946;--accent2:#ff6b6b;
  --gold:#f0a500;--green:#06d6a0;--blue:#4cc9f0;
  --text:#f0f0f5;--muted:#5a5a7a;--muted2:#8888a8;
  --border:rgba(255,255,255,0.05);
  --iconic-grad:linear-gradient(135deg,#e63946,#ffffff);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{width:100%;min-height:100vh;overflow-x:hidden;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 15% 40%,rgba(230,57,70,0.06) 0%,transparent 55%),radial-gradient(ellipse at 85% 20%,rgba(76,201,240,0.04) 0%,transparent 50%);pointer-events:none;z-index:0;}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;background:rgba(7,7,12,.98);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:200;backdrop-filter:blur(20px);}
.nav-brand{display:flex;flex-direction:column;text-decoration:none;gap:1px;}
.nav-logo-text{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:3px;display:flex;align-items:baseline;gap:5px;line-height:1;}
.grad{background:var(--iconic-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.white{color:#fff;}
.nav-formerly{font-size:8px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;}
.nav-right{display:flex;align-items:center;gap:8px;}
.back-btn{display:flex;align-items:center;gap:5px;color:var(--muted2);font-size:11px;font-weight:600;text-decoration:none;border:1px solid var(--border);padding:6px 13px;border-radius:20px;transition:all .2s;}
.back-btn:hover{color:var(--text);border-color:rgba(255,255,255,.15);}
.live-nav-badge{display:flex;align-items:center;gap:5px;background:rgba(230,57,70,.12);border:1px solid rgba(230,57,70,.3);color:var(--accent2);font-size:10px;font-weight:700;letter-spacing:1px;padding:5px 12px;border-radius:20px;}
.nav-dot{width:5px;height:5px;background:#e63946;border-radius:50%;animation:blink 1.2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

/* PLAYER */
.player-section{width:100%;background:#000;position:relative;}
.player-container{position:relative;width:100%;padding-bottom:56.25%;background:#000;overflow:hidden;}
.player-container iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none;}

/* Broadcaster badge */
.broadcaster-badge{position:absolute;top:14px;left:14px;z-index:10;display:flex;align-items:center;gap:8px;}
.bc-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.12);padding:6px 14px;border-radius:20px;}
.bc-dot{width:6px;height:6px;background:#e63946;border-radius:50%;animation:blink 1.2s infinite;flex-shrink:0;}
.bc-text{font-size:11px;font-weight:700;color:#fff;letter-spacing:.5px;}
.bc-text span{background:var(--iconic-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

/* Offline box */
.offline-box{position:absolute;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(7,7,12,.95);text-align:center;padding:24px;z-index:5;}
.offline-icon{width:60px;height:60px;background:rgba(230,57,70,.12);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:16px;border:1px solid rgba(230,57,70,.2);}
.offline-icon svg{width:28px;height:28px;fill:var(--accent);}
.offline-title{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;margin-bottom:8px;}
.offline-sub{font-size:13px;color:var(--muted2);margin-bottom:20px;line-height:1.6;max-width:280px;}
.yt-open-btn{display:inline-flex;align-items:center;gap:8px;background:#ff0000;color:#fff;font-weight:700;font-size:13px;padding:11px 24px;border-radius:10px;text-decoration:none;}

/* SCOREBOARD */
.scoreboard{position:relative;z-index:1;background:var(--bg2);border-bottom:1px solid var(--border);}
.score-inner{max-width:960px;margin:0 auto;padding:16px 20px;}
.score-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.score-match-title{font-size:12px;font-weight:700;color:var(--muted2);letter-spacing:1px;text-transform:uppercase;}
.score-status{display:flex;align-items:center;gap:6px;}
.score-live-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:blink 1.5s infinite;}
.score-status-text{font-size:11px;color:var(--green);font-weight:600;}
.score-manual-btn{font-size:10px;color:var(--muted);background:var(--bg3);border:1px solid var(--border);padding:3px 10px;border-radius:8px;cursor:pointer;transition:all .2s;}
.score-manual-btn:hover{color:var(--text);border-color:rgba(255,255,255,.15);}

/* Teams score row */
.teams-score{display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:center;margin-bottom:14px;}
.team-score-side{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:14px 16px;}
.team-score-side.batting{border-color:rgba(240,165,0,.2);background:rgba(240,165,0,.04);}
.ts-name{font-size:11px;color:var(--muted2);font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.ts-score{font-family:'Bebas Neue',sans-serif;font-size:clamp(24px,5vw,36px);letter-spacing:1px;color:var(--text);line-height:1;}
.ts-score .wkts{font-size:60%;color:var(--muted2);}
.ts-overs{font-size:11px;color:var(--muted);margin-top:3px;}
.ts-yet{font-size:13px;color:var(--muted);font-style:italic;padding:8px 0;}
.vs-badge{background:var(--bg4);border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-family:'Bebas Neue',sans-serif;font-size:14px;color:var(--muted);text-align:center;}

/* Current batting */
.current-play{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.cp-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px 14px;}
.cp-label{font-size:9px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;}
.cp-player{display:flex;align-items:center;justify-content:space-between;}
.cp-name{font-size:13px;font-weight:700;color:var(--text);}
.cp-stats{font-size:11px;color:var(--muted2);margin-top:2px;}
.cp-highlight{color:var(--gold);}

/* Run rate bar */
.rr-row{display:flex;align-items:center;gap:12px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:10px 14px;}
.rr-item{flex:1;text-align:center;}
.rr-val{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--text);}
.rr-lbl{font-size:9px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-top:1px;}
.rr-div{width:1px;height:32px;background:var(--border);}

/* Last ball */
.last-ball{display:flex;align-items:center;gap:8px;padding:8px 0 0;}
.lb-label{font-size:11px;color:var(--muted);}
.ball{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;}
.ball-dot{background:rgba(255,255,255,.08);color:var(--muted2);}
.ball-run{background:rgba(76,201,240,.12);border:1px solid rgba(76,201,240,.25);color:var(--blue);}
.ball-four{background:rgba(6,214,160,.12);border:1px solid rgba(6,214,160,.25);color:var(--green);}
.ball-six{background:rgba(240,165,0,.15);border:1px solid rgba(240,165,0,.3);color:var(--gold);}
.ball-wkt{background:rgba(230,57,70,.15);border:1px solid rgba(230,57,70,.3);color:var(--accent2);}
.ball-wide{background:rgba(139,92,246,.12);border:1px solid rgba(139,92,246,.25);color:#a78bfa;}

/* Manual update panel */
.manual-panel{display:none;background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:16px;margin-top:12px;}
.manual-panel.open{display:block;}
.mp-title{font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;}
.mp-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px;}
.mp-input{background:var(--bg4);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;width:100%;}
.mp-input:focus{outline:none;border-color:rgba(230,57,70,.4);}
.mp-input::placeholder{color:var(--muted);}
.mp-save{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;width:100%;}
.mp-save:hover{background:#c1121f;}

/* Channel info */
.channel-info{max-width:960px;margin:0 auto;padding:16px 20px 0;}
.broadcaster-strip{background:linear-gradient(135deg,rgba(230,57,70,.08),rgba(76,201,240,.05));border:1px solid rgba(230,57,70,.15);border-radius:14px;padding:16px 20px;display:flex;align-items:center;gap:16px;margin-bottom:16px;}
.bs-icon{width:48px;height:48px;background:linear-gradient(135deg,#e63946,#4cc9f0);border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:14px;color:#fff;letter-spacing:1px;flex-shrink:0;}
.bs-name{font-size:17px;font-weight:700;color:var(--text);}
.bs-sub{font-size:11px;color:var(--muted2);margin-top:2px;}
.bs-badges{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap;}
.bs-badge{font-size:9px;font-weight:700;letter-spacing:1px;padding:3px 10px;border-radius:20px;}
.bb-official{background:rgba(240,165,0,.1);border:1px solid rgba(240,165,0,.25);color:var(--gold);}
.bb-live{background:rgba(230,57,70,.1);border:1px solid rgba(230,57,70,.25);color:var(--accent2);}
.bb-free{background:rgba(6,214,160,.08);border:1px solid rgba(6,214,160,.2);color:var(--green);}

/* Info cards */
.info-wrap{max-width:960px;margin:0 auto;padding:0 20px 24px;}
.info-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:16px 18px;margin-bottom:12px;}
.info-head{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;}
.info-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;}
.info-cell{background:var(--bg3);border-radius:9px;padding:10px 12px;}
.cell-lbl{font-size:9px;color:var(--muted);margin-bottom:3px;letter-spacing:.5px;}
.cell-val{font-size:12px;font-weight:600;color:var(--text);}
.cell-val.green{color:var(--green);}
.cell-val.blue{color:var(--blue);}
.cell-val.gold{color:var(--gold);}
.cell-val.iconic{background:var(--iconic-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

/* Other channels */
.other-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;}
.other-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px;text-decoration:none;display:flex;align-items:center;gap:10px;transition:all .2s;}
.other-card:hover{border-color:rgba(230,57,70,.25);transform:translateY(-1px);}
.oc-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:11px;color:#fff;flex-shrink:0;}
.oc-name{font-size:12px;font-weight:600;color:var(--text);}
.oc-sub{font-size:10px;color:var(--muted2);margin-top:1px;}

/* YouTube branding */


footer{text-align:center;padding:18px;font-size:10px;color:var(--muted);border-top:1px solid var(--border);letter-spacing:.5px;}

@media(max-width:640px){
  .teams-score{grid-template-columns:1fr auto 1fr;gap:8px;}
  .ts-score{font-size:24px;}
  .current-play{grid-template-columns:1fr 1fr;}
  .mp-grid{grid-template-columns:1fr;}
  .info-grid{grid-template-columns:1fr 1fr;}
  .other-grid{grid-template-columns:1fr 1fr;}
  .bs-sub{display:none;}
}
@media(max-width:380px){
  .teams-score{grid-template-columns:1fr 30px 1fr;}
  .ts-score{font-size:20px;}
  .rr-row{gap:6px;}
  .rr-val{font-size:16px;}
}
</style>
</head>
