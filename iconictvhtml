<script>
var manualOpen = false;

function toggleManual() {
  manualOpen = !manualOpen;
  document.getElementById('manual-panel').classList.toggle('open', manualOpen);
}

function saveManual() {
  var t1name = document.getElementById('inp-t1name').value.trim().toUpperCase();
  var t1score = document.getElementById('inp-t1score').value.trim();
  var t1overs = document.getElementById('inp-t1overs').value.trim();
  var t2name = document.getElementById('inp-t2name').value.trim().toUpperCase();
  var t2score = document.getElementById('inp-t2score').value.trim();
  var t2overs = document.getElementById('inp-t2overs').value.trim();
  var bat1 = document.getElementById('inp-bat1').value.trim();
  var bat2 = document.getElementById('inp-bat2').value.trim();
  var bowl = document.getElementById('inp-bowl').value.trim();
  var crr = document.getElementById('inp-crr').value.trim();
  var rrr = document.getElementById('inp-rrr').value.trim();
  var balls = document.getElementById('inp-balls').value.trim();

  if (t1name) { document.getElementById('team1-name').textContent = t1name; }
  if (t1score) {
    var parts = t1score.split('/');
    document.getElementById('team1-score').innerHTML = parts[0] + (parts[1] ? '<span class="wkts">/' + parts[1] + '</span>' : '');
  }
  if (t1overs) { document.getElementById('team1-overs').textContent = t1overs; }
  if (t2name) { document.getElementById('team2-name').textContent = t2name; }
  if (t2score) {
    if (t2score.toLowerCase().includes('yet') || t2score === '—') {
      document.getElementById('team2-score').innerHTML = '<span style="font-size:13px;color:var(--muted);font-style:italic;font-family:\'DM Sans\'">Yet to bat</span>';
    } else {
      var parts2 = t2score.split('/');
      document.getElementById('team2-score').innerHTML = parts2[0] + (parts2[1] ? '<span class="wkts">/' + parts2[1] + '</span>' : '');
    }
  }
  if (t2overs) { document.getElementById('team2-overs').textContent = t2overs; }

  if (bat1) {
    var b1 = bat1.match(/^(.+?)\s+(\d+)\((\d+)\)$/);
    if (b1) {
      document.getElementById('bat1-name').textContent = b1[1];
      document.getElementById('bat1-runs').textContent = b1[2];
      document.getElementById('bat1-balls').textContent = b1[3];
    } else {
      document.getElementById('bat1-name').textContent = bat1;
    }
  }
  if (bat2) {
    var b2 = bat2.match(/^(.+?)\s+(\d+)\((\d+)\)$/);
    if (b2) {
      document.getElementById('bat2-name').textContent = b2[1];
      document.getElementById('bat2-runs').textContent = b2[2];
      document.getElementById('bat2-balls').textContent = b2[3];
    } else {
      document.getElementById('bat2-name').textContent = bat2;
    }
  }
  if (bowl) {
    var bwl = bowl.split('-');
    document.getElementById('bowl-name').textContent = bwl[0] ? bwl[0].trim() : bowl;
    if (bwl.length >= 4) {
      document.getElementById('bowl-overs').textContent = bwl[0].trim().split(' ').pop() || '—';
      document.getElementById('bowl-runs').textContent = bwl[2] || '—';
      document.getElementById('bowl-wkts').textContent = bwl[3] || '—';
    }
  }
  if (crr) { document.getElementById('crr').textContent = crr; }
  if (rrr) { document.getElementById('rrr').textContent = rrr; }

  if (balls) {
    var ballArr = balls.split(',');
    var container = document.getElementById('balls-container');
    container.innerHTML = '';
    ballArr.forEach(function(b) {
      b = b.trim();
      var el = document.createElement('div');
      el.className = 'ball';
      el.textContent = b;
      if (b === '0' || b === '.') el.classList.add('ball-dot');
      else if (b === '4') el.classList.add('ball-four');
      else if (b === '6') el.classList.add('ball-six');
      else if (b.toUpperCase() === 'W') el.classList.add('ball-wkt');
      else if (b.toUpperCase() === 'WD' || b.toUpperCase() === 'NB') el.classList.add('ball-wide');
      else el.classList.add('ball-run');
      container.appendChild(el);
    });
    document.getElementById('last-balls-row').style.display = 'flex';
  }

  document.getElementById('score-status').textContent = 'Updated · ' + new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});
  toggleManual();
}

// Auto-fetch from cricket-api.vercel.app (Cricbuzz scraper)
function fetchLiveScore() {
  var cricbuzzUrl = 'https://www.cricbuzz.com/live-cricket-scorecard/';
  fetch('https://cricket-api.vercel.app/cri.php?url=' + encodeURIComponent(cricbuzzUrl))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data && data.livescore) {
        document.getElementById('score-status').textContent = 'Auto · ' + new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});
      }
    })
    .catch(function() {
      // API unavailable - manual mode only
    });
}

// Try auto-fetch every 30s (falls back to manual gracefully)
fetchLiveScore();
setInterval(fetchLiveScore, 30000);

// Check if embed blocked after 6s
setTimeout(function() {
  var iframe = document.getElementById('yt-player');
  try {
    if (iframe.contentDocument && iframe.contentDocument.body.innerHTML === '') {
      document.getElementById('offline-box').style.display = 'flex';
    }
  } catch(e) {}
}, 6000);
</script>
